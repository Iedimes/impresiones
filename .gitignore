/node_modules
/public/hot
/public/storage
/storage/*.key
/vendor
.env
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log

# Ignorar assets compilados (se generan al correr npm run dev)
/public/css/app.css
/public/js/app.js
/public/mix-manifest.json
/public/service-worker.js

# Ignorar documentos generados
storage/*/impresion/*.pdf
storage/*/impresion/*.docx
storage/*/impresion/*.zip
storage/*/impresion/*.png

# Mantener las carpetas pero vacías
!storage/*/impresion/.gitignore

# Archivos de sistema y log
.vscode/
/storage/logs/*.log
/storage/framework/sessions/*
/storage/framework/views/*
/storage/framework/cache/*
